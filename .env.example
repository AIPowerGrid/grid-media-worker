# ComfyUI Bridge for AI Power Grid — example configuration
# Copy to .env and adjust:   cp .env.example .env

# --- Required ---
GRID_API_KEY=your_powergrid_api_key            # https://console.aipowergrid.io/dashboard/api-key

# --- Worker identity (optional) ---
GRID_WORKER_NAME=MyComfyWorker                 # shown on the network

# --- Endpoints (optional; defaults shown) ---
COMFYUI_URL=http://127.0.0.1:8188              # ComfyUI's default port is 8188
GRID_API_URL=https://api.aipowergrid.io
# Local setup UI. Bind wider only behind an authenticated network boundary.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=7860

# --- Current worker transport ---
# Push dispatch over WebSocket + direct-to-R2 presigned uploads (no polling).

# --- Managed profile (ACE-Step V1 development; leave unset for normal workers) ---
# A signed, active profile + matching canary state becomes the model/job-type
# authority. A runtime-specific startup check replaces generic ComfyUI preflight
# for direct ACE-Step workers.
# GRID_PROFILE_PATH=/absolute/path/to/ace-step-v1.profile.json
# GRID_PROFILE_STATE_PATH=/home/you/.aipg/media-worker/profile-state.json

# Managed profiles also require a payout-wallet delegation to a funds-less
# worker signer. Generate the key and wallet-signable request with:
#   grid-media-manager identity generate
#   grid-media-manager identity request --payout-wallet 0x...
# GRID_WORKER_KEY_PATH=/home/you/.aipg/media-worker/worker-key.json
# GRID_WORKER_DELEGATION_PATH=/home/you/.aipg/media-worker/delegation.json
# ACE_STEP_API_URL=http://127.0.0.1:8001
# ACE_STEP_API_KEY=                              # optional local runtime auth
# ACE_STEP_JOB_TIMEOUT=1800                      # below Core's outer deadlines

# --- Generation settings (optional) ---
GRID_NSFW=false                                # allow NSFW jobs? true/false
GRID_THREADS=2                                 # concurrent jobs
GRID_MAX_PIXELS=1048576                        # max output resolution (pixels)

# --- Models (optional) ---
# Comma-separated grid model names. If unset, the bridge auto-detects from
# your installed ComfyUI checkpoints.
# GRID_MODEL=stable_diffusion, Flux.1-Krea-dev Uncensored (fp8+CLIP+VAE)

# --- Workflow template (optional) ---
# Path to a ComfyUI JSON workflow export in your workflows/ directory.
# WORKFLOW_FILE=my_workflow.json
