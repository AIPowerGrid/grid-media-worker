# ComfyUI Bridge for AI Power Grid — example configuration
# Copy to .env and adjust:   cp .env.example .env

# --- Required ---
GRID_API_KEY=your_powergrid_api_key            # https://console.aipowergrid.io/dashboard/api-key

# --- Worker identity (optional) ---
GRID_WORKER_NAME=MyComfyWorker                 # shown on the network

# --- Endpoints (optional; defaults shown) ---
COMFYUI_URL=http://127.0.0.1:8188              # ComfyUI's default port is 8188
GRID_API_URL=https://api.aipowergrid.io

# --- Current worker transport ---
# Push dispatch over WebSocket + direct-to-R2 presigned uploads (no polling).
GRID_WS=true

# --- Generation settings (optional) ---
GRID_NSFW=false                                # allow NSFW jobs? true/false
GRID_THREADS=2                                 # concurrent jobs
GRID_MAX_PIXELS=1048576                        # max output resolution (pixels)

# --- Models (optional) ---
# Comma-separated grid model names. If unset, the bridge auto-detects from
# your installed ComfyUI checkpoints.
# GRID_MODEL=stable_diffusion, Flux.1-Krea-dev Uncensored (fp8+CLIP+VAE)

# --- Workflow template (optional) ---
# Path to a ComfyUI JSON workflow export in your workflows/ directory.
# WORKFLOW_FILE=my_workflow.json
